rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['mainadmin', 'subadmin'] &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved';
    }

    function isMainAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'mainadmin';
    }

    match /users/{userId} {
      // নিজের ডকুমেন্ট নিজে পড়তে পারবে, অ্যাডমিন সবারটা পড়তে পারবে
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());

      // সাইনআপের সময় নিজের ডকুমেন্ট বানাতে পারবে, কিন্তু role/status জোর করে বসাতে হবে
      allow create: if isSignedIn() &&
        request.auth.uid == userId &&
        request.resource.data.role == 'student' &&
        request.resource.data.status == 'pending';

      // অ্যাডমিন যেকোনো ইউজার আপডেট করতে পারবে (অ্যাপ্রুভ/রিজেক্ট/ওভাররাইট)
      // মেইন অ্যাডমিন ছাড়া কেউ role কে admin বানাতে পারবে না
      allow update: if isAdmin() &&
        (!("role" in request.resource.data) ||
         request.resource.data.role == resource.data.role ||
         isMainAdmin());

      // শুধু অ্যাডমিন ডিলিট করতে পারবে
      allow delete: if isAdmin();
    }

    function isApprovedUser() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved';
    }

    // ===== মিল সাইকেল (মাস) =====
    match /cycles/{cycleId} {
      // সব অ্যাপ্রুভড ইউজার (স্টুডেন্ট+অ্যাডমিন) সাইকেল তথ্য পড়তে পারবে
      allow read: if isApprovedUser();
      // শুধু অ্যাডমিন নতুন সাইকেল বানাতে/আপডেট করতে পারবে
      allow write: if isAdmin();

      // ===== প্রতিদিনের মিল এন্ট্রি (প্রতি ইউজারের জন্য একটা ডকুমেন্ট) =====
      match /mealEntries/{userId} {
        // নিজেরটা নিজে পড়তে পারবে, অ্যাডমিন সবারটা পড়তে পারবে
        allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());

        // নিজে নিজের এন্ট্রি বানাতে/আপডেট করতে পারবে, অ্যাডমিন যেকারো এন্ট্রি ওভাররাইট করতে পারবে
        allow create, update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }

      // ===== স্পেশাল ডে মিল ভ্যালু =====
      match /specialMealValues/{dateId} {
        allow read: if isApprovedUser();
        allow write: if isAdmin();
      }

      // ===== গেস্ট মিল =====
      match /guestMeals/{entryId} {
        allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
        allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
      }

      // ===== পেমেন্ট (শুধু অ্যাডমিন দেখতে/লিখতে পারবে) =====
      match /payments/{paymentId} {
        allow read, write: if isAdmin();
      }
    }

    // নোটিফিকেশন কালেকশন
    match /notifications/{userId}/items/{notifId} {
      // নিজের নোটিফিকেশন নিজে পড়তে/মার্ক-রিড করতে পারবে, অ্যাডমিন সবারটা পড়তে পারবে
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow update: if isSignedIn() && request.auth.uid == userId;
      // অ্যাডমিন যেকোনো ইউজারকে নোটিফিকেশন পাঠাতে পারবে (ওভাররাইট এলার্ট ইত্যাদি)
      allow create: if isAdmin();
    }
  }
}
